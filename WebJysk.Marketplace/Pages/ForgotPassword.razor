@page "/forgot-password"
@inject AuthApiService AuthApi
@inject NavigationManager Nav
@layout MainLayout

<PageTitle>Forgot Password - JYSK</PageTitle>

<div class="auth-page">
    <div class="auth-card login-card">
        <h2 class="login-title">Forgot Password</h2>
        <p class="login-subtitle">Enter your email and we'll send you a link to reset your password.</p>

        @if (_sent)
        {
            <div class="alert alert-success">
                If an account exists for that email, you will receive a reset link shortly. Check your inbox and spam folder.
            </div>
            <NavLink href="/login" class="btn btn-primary login-submit">Back to Login</NavLink>
        }
        else
        {
            <EditForm Model="_email" OnValidSubmit="SendResetLink">
                <div class="login-form mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="_email" class="form-control" placeholder="your@email.com" />
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }
                <button type="submit" class="btn btn-primary w-100 login-submit" disabled="@_loading">
                    @(_loading ? "Sending..." : "Send Reset Link")
                </button>
            </EditForm>
            <NavLink href="/login" class="login-back d-block mt-2">← Back to Login</NavLink>
        }
    </div>
</div>

@code {
    private string _email = "";
    private bool _sent;
    private bool _loading;
    private string? _error;

    private async Task SendResetLink()
    {
        if (string.IsNullOrWhiteSpace(_email)) return;
        _error = null;
        _loading = true;
        try
        {
            _sent = await AuthApi.ForgotPasswordAsync(_email.Trim());
        }
        catch (Exception ex)
        {
            _error = "Could not connect. Please try again.";
        }
        finally { _loading = false; }
    }
}
