@page "/checkout/success"
@inject NavigationManager Nav

<PageTitle>Order Placed - Jysk</PageTitle>

<div class="jysk-order-success">
    <div class="jysk-order-success-card">
        <div class="jysk-order-success-icon">✓</div>
        <h1 class="jysk-order-success-title">Thank you for your order!</h1>
        <p class="jysk-order-success-text">Your order has been placed successfully.</p>

        <div class="jysk-order-success-delivery">
            <span class="jysk-order-success-delivery-icon">🚚</span>
            <div>
                <strong>What happens next?</strong>
                <p>Our courier will pick up your order and deliver it to your address. You will receive a message when your delivery has been taken and is on the way. We'll also notify you when it has been delivered.</p>
            </div>
        </div>

        <div class="jysk-order-success-actions">
            <NavLink href="/products" class="jysk-order-success-btn-primary">Continue Shopping</NavLink>
            <NavLink href="/" class="jysk-order-success-btn-secondary">Home</NavLink>
        </div>
    </div>
</div>
