        </div>
        <h2 class="mb-3">Thank you for your order!</h2>
        <p class="text-muted mb-4">Your order has been placed successfully.</p>
        <NavLink href="/products" class="btn btn-primary me-2">Continue Shopping</NavLink>
        <NavLink href="/" class="btn btn-outline-secondary">Home</NavLink>
    </div>
</div>
