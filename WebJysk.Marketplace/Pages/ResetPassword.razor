@page "/reset-password"
@inject AuthApiService AuthApi
@inject NavigationManager Nav
@layout MainLayout

<PageTitle>Reset Password - JYSK</PageTitle>

<div class="auth-page">
    <div class="auth-card login-card">
                <h2 class="login-title mb-3">Reset Password</h2>
                    @if (string.IsNullOrEmpty(_email) || string.IsNullOrEmpty(_token))
                    {
                        <div class="alert alert-warning">
                            Invalid or expired reset link. Please request a new one from the
                            <NavLink href="/forgot-password">forgot password</NavLink> page.
                        </div>
                    }
                    else if (_success)
                    {
                        <div class="alert alert-success">Your password has been reset. You can now log in.</div>
                        <NavLink href="/login" class="btn btn-primary">Go to Login</NavLink>
                    }
                    else
                    {
                        <EditForm Model="_model" OnValidSubmit="HandleReset">
                            <div class="login-form mb-3">
                                <label class="form-label">New Password</label>
                                <InputText type="password" @bind-Value="_model.NewPassword" class="form-control" placeholder="••••••••" />
                            </div>
                            <div class="login-form mb-3">
                                <label class="form-label">Confirm Password</label>
                                <InputText type="password" @bind-Value="_model.ConfirmPassword" class="form-control" placeholder="••••••••" />
                                @if (_model.NewPassword != _model.ConfirmPassword && !string.IsNullOrEmpty(_model.ConfirmPassword))
                                {
                                    <span class="text-danger small">Passwords do not match</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <div class="login-error">@_error</div>
                            }
                            <button type="submit" class="btn btn-primary w-100 login-submit" disabled="@(_loading || _model.NewPassword != _model.ConfirmPassword)">
                                @(_loading ? "Resetting..." : "Reset Password")
                            </button>
                        </EditForm>
                    }
    </div>
</div>

@code {
    private string? _email;
    private string? _token;
    private ResetModel _model = new();
    private bool _loading;
    private bool _success;
    private string? _error;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        if (string.IsNullOrEmpty(uri.Query)) return;
        foreach (var part in uri.Query.TrimStart('?').Split('&'))
        {
            var kv = part.Split('=', 2, StringSplitOptions.None);
            if (kv.Length != 2) continue;
            var key = Uri.UnescapeDataString(kv[0]);
            var val = Uri.UnescapeDataString(kv[1]);
            if (key.Equals("email", StringComparison.OrdinalIgnoreCase)) _email = val;
            if (key.Equals("token", StringComparison.OrdinalIgnoreCase)) _token = val;
        }
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(_email) || string.IsNullOrEmpty(_token) ||
            _model.NewPassword != _model.ConfirmPassword ||
            _model.NewPassword?.Length < 8) return;

        _error = null;
        _loading = true;
        try
        {
            var (success, err) = await AuthApi.ResetPasswordAsync(_email, _token, _model.NewPassword!);
            if (success)
                _success = true;
            else
                _error = err ?? "Reset failed. The link may have expired.";
        }
        catch
        {
            _error = "Could not connect. Please try again.";
        }
        finally { _loading = false; }
    }

    private class ResetModel
    {
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
