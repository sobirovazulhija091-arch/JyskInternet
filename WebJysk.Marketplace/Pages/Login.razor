@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav
@layout MainLayout

<PageTitle>Login - JYSK</PageTitle>

<div class="login-page auth-page">
    <div class="login-card auth-card">
        <h2 class="login-title">Sign in</h2>
        <p class="login-subtitle">Log in to add items to cart and place orders</p>

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <div class="login-form">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="_model.Email" class="form-control" placeholder="your@email.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" @bind-Value="_model.Password" class="form-control" placeholder="••••••••" />
                </div>
                <div class="mb-2">
                    <NavLink href="/forgot-password" class="small text-muted">Forgot password?</NavLink>
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }
                <button type="submit" class="btn btn-primary w-100 login-submit" disabled="@_loading">
                    @(_loading ? "Signing in..." : "Sign in")
                </button>
            </div>
        </EditForm>

        <p class="mt-3 mb-0">Don't have an account? <NavLink href="/register">Register</NavLink></p>
        <NavLink href="/" class="login-back d-block mt-2">← Back to welcome</NavLink>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;
        try
        {
            var (success, err) = await Auth.LoginAsync(_model.Email!, _model.Password!);
            if (success)
                Nav.NavigateTo("/home", true);
            else
                _error = err ?? "Invalid email or password.";
        }
        finally { _loading = false; }
    }

    private class LoginModel
    {
        public string? Email { get; set; }
        public string? Password { get; set; }
    }
}
