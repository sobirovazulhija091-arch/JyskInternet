@page "/checkout"
@inject CartService CartService
@inject OrderApiService OrderApi
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Checkout - Jysk</PageTitle>

@if (!_canCheckout)
{
    <div class="container py-5 text-center">
        <p class="mb-3">Please log in to checkout.</p>
        <NavLink href="/login" class="btn btn-primary">Log in</NavLink>
    </div>
}
else if (!_items.Any())
{
    <div class="container py-5 text-center">
        <p class="mb-3">Your cart is empty.</p>
        <NavLink href="/products" class="btn btn-primary">Browse Products</NavLink>
    </div>
}
else
{
    <div class="jysk-checkout-page">
        <div class="jysk-checkout-header">
            <h1 class="jysk-checkout-title">Checkout</h1>
            <p class="jysk-checkout-subtitle">Complete your order and our courier will deliver to you</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="jysk-checkout-error">@_error</div>
        }

        <div class="jysk-checkout-grid">
            <div class="jysk-checkout-form-col">
                <div class="jysk-checkout-delivery-info">
                    <span class="jysk-checkout-delivery-icon">🚚</span>
                    <div>
                        <strong>Home delivery</strong>
                        <p>Our courier will bring your order to the address below. You'll receive a message when your delivery is on the way and when it has been completed.</p>
                    </div>
                </div>

                <EditForm Model="_model" OnValidSubmit="PlaceOrder">
                    <DataAnnotationsValidator />
                    <div class="jysk-checkout-card">
                        <h3 class="jysk-checkout-card-title">Delivery Address</h3>
                        <div class="jysk-checkout-field">
                            <label class="jysk-checkout-label">Full address</label>
                            <InputTextArea class="jysk-checkout-input" @bind-Value="_model.DeliveryAddress" rows="3" placeholder="Street, City, Postal Code" />
                            <ValidationMessage For="@(() => _model.DeliveryAddress)" class="jysk-checkout-validation" />
                        </div>
                        <div class="jysk-checkout-field">
                            <label class="jysk-checkout-label">Payment method</label>
                            <InputSelect class="jysk-checkout-select" @bind-Value="_paymentMethodStr">
                                <option value="0">Cash on delivery</option>
                                <option value="1">Card</option>
                                <option value="2">Online</option>
                            </InputSelect>
                        </div>
                    </div>
                    <button type="submit" class="jysk-checkout-btn" disabled="@_submitting">
                        @if (_submitting) { <span>Placing order...</span> }
                        else { <span>Place Order</span> }
                    </button>
                </EditForm>
            </div>

            <div class="jysk-checkout-summary-col">
                <div class="jysk-checkout-card jysk-checkout-summary">
                    <h3 class="jysk-checkout-card-title">Order summary</h3>
                    <ul class="jysk-checkout-items">
                        @foreach (var item in _items)
                        {
                            <li class="jysk-checkout-item">
                                <span>@item.ProductName × @item.Quantity</span>
                                <span>@((item.Price * item.Quantity).ToString("C"))</span>
                            </li>
                        }
                    </ul>
                    <div class="jysk-checkout-total">
                        <span>Total</span>
                        <span>@_total.ToString("C")</span>
                    </div>
                </div>
                <NavLink href="/cart" class="jysk-checkout-back">← Back to cart</NavLink>
            </div>
        </div>
    </div>
}

@code {
    private bool _canCheckout;
    private List<CartItem> _items = [];
    private decimal _total;
    private CreateOrderDto _model = new();
    private bool _submitting;
    private string? _error;

    private string _paymentMethodStr = "0";

    protected override async Task OnInitializedAsync()
    {
        _canCheckout = await Auth.IsAuthenticatedAsync();
        if (!_canCheckout) return;
        _items = await CartService.GetItemsAsync();
        _total = _items.Sum(i => i.Price * i.Quantity);
        _model.TotalAmount = _total;
        _model.Status = 1;
        _model.PaymentMethod = 0;
    }

    private async Task PlaceOrder()
    {
        _error = null;
        _submitting = true;
        try
        {
            _model.PaymentMethod = int.TryParse(_paymentMethodStr, out var pm) ? pm : 0;
            _model.Items = _items.Select(i => new OrderItemDto
            {
                ProductId = i.ProductId,
                Quantity = i.Quantity,
                Price = i.Price
            }).ToList();

            var (success, err) = await OrderApi.CreateOrderAsync(_model);
            if (success)
            {
                await CartService.ClearAsync();
                Nav.NavigateTo("/checkout/success", true);
            }
            else
            {
                _error = err ?? "Order failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }
}
