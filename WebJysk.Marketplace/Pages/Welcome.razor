@page "/"
@inject AuthService Auth
@inject NavigationManager Nav
@layout MainLayout

<PageTitle>Welcome - JYSK</PageTitle>

<div class="welcome-page">
    <div class="welcome-card">
        <h1 class="welcome-title">Welcome to JYSK</h1>
        <p class="welcome-subtitle">Choose how you'd like to continue</p>

        <div class="welcome-actions">
            <NavLink href="/register" class="welcome-btn welcome-btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Create account
            </NavLink>
            <NavLink href="/login" class="welcome-btn welcome-btn-outline mt-2">
                Sign in
            </NavLink>
        </div>

        <p class="welcome-hint">
            Please register or sign in to browse our store and place orders.
        </p>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (await Auth.IsAuthenticatedAsync())
            Nav.NavigateTo("/home", true);
    }
}
