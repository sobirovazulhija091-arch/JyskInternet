@page "/product/{Id:int}"
@inject ProductApiService ProductApi
@inject CartService Cart
@inject AuthService Auth
@inject ReviewApiService ReviewApi
@inject NavigationManager Nav

<PageTitle>@(_product?.Name ?? "Product") - JYSK</PageTitle>

<div class="jysk-product-detail">
    @if (_loading)
    {
        <div class="container text-center py-5">
            <div class="jysk-spinner-large"></div>
            <p class="mt-3">Loading...</p>
        </div>
    }
    else if (_product == null)
    {
        <div class="container py-5">
            <p>Product not found.</p>
            <NavLink href="/products" class="jysk-link">← Back to products</NavLink>
        </div>
    }
    else
    {
        <div class="container">
            <nav class="jysk-breadcrumb" aria-label="breadcrumb">
                <NavLink href="/home">Home</NavLink>
                <span class="jysk-breadcrumb-sep">/</span>
                <NavLink href="/products">Products</NavLink>
                @if (_product.Category != null)
                {
                    <span class="jysk-breadcrumb-sep">/</span>
                    <NavLink href="@($"/products?category={_product.Category.Id}")">@_product.Category.Name</NavLink>
                }
                <span class="jysk-breadcrumb-sep">/</span>
                <span class="jysk-breadcrumb-current">@_product.Name</span>
            </nav>

            <div class="jysk-product-detail-grid">
                <div class="jysk-product-detail-image">
                    <div class="jysk-product-detail-placeholder"></div>
                </div>
                <div class="jysk-product-detail-info">
                    @if (_product.Category != null)
                    {
                        <NavLink href="@($"/products?category={_product.Category.Id}")" class="jysk-product-category-link">@_product.Category.Name</NavLink>
                    }
                    <h1 class="jysk-product-detail-title">@_product.Name</h1>
                    <div class="jysk-product-detail-price">
                        @if (_product.DiscountPrice > 0)
                        {
                            <span class="jysk-price-current">@_product.DiscountPrice.ToString("N2") SM</span>
                            <span class="jysk-price-old">@_product.Price.ToString("N2") SM</span>
                        }
                        else
                        {
                            <span class="jysk-price-current">@_product.Price.ToString("N2") SM</span>
                        }
                    </div>
                    <p class="jysk-product-detail-desc">@_product.Description</p>
                    <div class="jysk-product-meta">
                        <span>Article: @_product.Id</span>
                        @if (_product.Category != null)
                        {
                            <span>Category: <NavLink href="@($"/products?category={_product.Category.Id}")">@_product.Category.Name</NavLink></span>
                        }
                        <span>In stock: @_product.StockQuantity</span>
                    </div>
                    <div class="jysk-product-detail-actions">
                        @if (_canAddToCart)
                        {
                            <input type="number" class="jysk-qty-input" @bind="_quantity" min="1" max="@_product.StockQuantity" />
                            <button class="jysk-btn-add-lg" @onclick="AddToCart">Add to Cart</button>
                        }
                        else
                        {
                            <NavLink href="/login" class="jysk-btn-add-lg jysk-btn-login-link">Login to add to cart</NavLink>
                        }
                    </div>
                    @if (_added)
                    {
                        <p class="jysk-added-msg">✓ Added to cart!</p>
                    }

                    <hr class="my-4" />
                    <h4 class="mb-3">Reviews (Otziv)</h4>
                    @if (_canAddToCart && !_reviewSubmitted)
                    {
                        <div class="jysk-review-form mb-4">
                            <div class="mb-2">
                                <label class="form-label">Your rating (1-5)</label>
                                <select class="form-select" style="max-width:100px" @bind="_reviewRating">
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                    <option value="4">4</option>
                                    <option value="5">5</option>
                                </select>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Comment</label>
                                <InputTextArea class="form-control" rows="2" @bind-Value="_reviewComment" placeholder="Write your review..." />
                            </div>
                            <button class="btn btn-primary btn-sm" @onclick="SubmitReview" disabled="@_reviewSubmitting">@(_reviewSubmitting ? "Sending..." : "Add review")</button>
                            @if (!string.IsNullOrEmpty(_reviewError))
                            {
                                <p class="text-danger small mt-2">@_reviewError</p>
                            }
                        </div>
                    }
                    else if (!_canAddToCart)
                    {
                        <p class="text-muted small">Log in to add a review.</p>
                    }
                    @if (_reviews?.Any() == true)
                    {
                        <div class="jysk-reviews-list">
                            @foreach (var r in _reviews)
                            {
                                <div class="jysk-review-card mb-2 p-3 border rounded">
                                    <strong>@(r.User?.FullName ?? "User")</strong>
                                    <span class="text-warning ms-2">★ @r.Rating</span>
                                    <p class="mb-0 mt-1 small">@r.Comment</p>
                                </div>
                            }
                        </div>
                    }
                    else if (_reviews != null && !_reviews.Any())
                    {
                        <p class="text-muted small">No reviews yet. Be the first to review!</p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Product? _product;
    private bool _loading = true;
    private int _quantity = 1;
    private bool _added;
    private bool _canAddToCart = true;
    private List<ReviewModel>? _reviews;
    private int _reviewRating = 5;
    private string _reviewComment = "";
    private bool _reviewSubmitting;
    private bool _reviewSubmitted;
    private string? _reviewError;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _canAddToCart = await Auth.IsAuthenticatedAsync();
        _product = await ProductApi.GetByIdAsync(Id);
        _reviews = await ReviewApi.GetProductReviewsAsync(Id);
        _loading = false;
    }

    private async Task AddToCart()
    {
        if (_product == null) return;
        await Cart.AddAsync(_product, _quantity);
        _added = true;
    }

    private async Task SubmitReview()
    {
        if (_product == null || string.IsNullOrWhiteSpace(_reviewComment)) return;
        _reviewError = null;
        _reviewSubmitting = true;
        var (success, err) = await ReviewApi.AddReviewAsync(Id, _reviewRating, _reviewComment.Trim());
        _reviewSubmitting = false;
        if (success)
        {
            _reviewSubmitted = true;
            _reviewComment = "";
            _reviews = await ReviewApi.GetProductReviewsAsync(Id);
        }
        else
        {
            _reviewError = err;
        }
    }
}
