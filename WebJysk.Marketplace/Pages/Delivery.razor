@page "/delivery"
@layout MainLayout

<PageTitle>Delivery - JYSK</PageTitle>

<div class="delivery-page">
    <div class="container">
        <div class="delivery-header">
            <h1 class="delivery-title">Delivery Information</h1>
            <p class="delivery-lead">Fast and reliable delivery to your doorstep</p>
        </div>

        <div class="delivery-cards">
            <div class="delivery-card">
                <div class="delivery-card-icon">📦</div>
                <h3>Standard Delivery</h3>
                <p>Delivery within 3–5 business days. Free on orders over 500 TJS.</p>
                <span class="delivery-badge">Most popular</span>
            </div>
            <div class="delivery-card">
                <div class="delivery-card-icon">⚡</div>
                <h3>Express Delivery</h3>
                <p>Next-day delivery for orders placed before 2 PM. Additional fee applies.</p>
            </div>
            <div class="delivery-card">
                <div class="delivery-card-icon">🏪</div>
                <h3>Store Pickup</h3>
                <p>Order online and collect from your nearest JYSK store. Free of charge.</p>
            </div>
        </div>

        <div class="delivery-info">
            <h2>How it works</h2>
            <ol class="delivery-steps">
                <li><strong>Place your order</strong> — Browse products and add them to your cart.</li>
                <li><strong>Choose delivery option</strong> — Select the option that suits you best.</li>
                <li><strong>Track your order</strong> — Receive updates via email or SMS.</li>
                <li><strong>Enjoy</strong> — Your order arrives at your door or is ready for pickup.</li>
            </ol>
        </div>

        <div class="delivery-contact">
            <p>Questions about delivery? Contact us at <a href="tel:+992446252200" class="delivery-link">+992 (44) 6252200</a> or visit our <NavLink href="/about" class="delivery-link">About JYSK</NavLink> page.</p>
        </div>
    </div>
</div>
