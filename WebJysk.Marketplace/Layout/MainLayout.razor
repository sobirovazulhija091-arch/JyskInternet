                </div>
            </div>
        </div>
    </div>

    <!-- Main header -->
    <header class="jysk-header">
        <div class="container">
            <div class="jysk-header-inner">
                <NavLink href="/home" class="jysk-logo">JYSK</NavLink>
                <nav class="jysk-nav">
                    <NavLink href="/home" class="jysk-nav-link">Home</NavLink>
                    <NavLink href="/categories" class="jysk-nav-link">Catalog</NavLink>
                    <NavLink href="/delivery" class="jysk-nav-link">Delivery</NavLink>
                    <MoreDropdown />
                </nav>
                <div class="jysk-header-actions">
                    @if (_isAdmin)
                    {
                        <a href="http://localhost:5271" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary me-2">Admin Panel</a>
                    }
                    <NavLink href="/products" class="jysk-action-btn" aria-label="Search">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    </NavLink>
                    @if (_canUseCart)
                    {
                        <NavLink href="/cart" class="jysk-action-btn jysk-cart position-relative" aria-label="Cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                            @if (_cartCount > 0)
                            {
                                <span class="jysk-cart-badge">@_cartCount</span>
                            }
                        </NavLink>
                    }
                    else
                    {
                        <NavLink href="/login" class="jysk-action-btn" aria-label="Login to use cart" title="Login to add to cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                            <span class="ms-1 d-none d-md-inline">Login</span>
                        </NavLink>
                    }
                    @if (_isLoggedIn)
                    {
                        <NavLink href="/account" class="btn btn-sm btn-outline-primary ms-1">Account</NavLink>
                        <button type="button" class="btn btn-sm btn-outline-secondary ms-1" @onclick="Logout">Logout</button>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="jysk-main">
        @Body
    </main>

    <!-- Footer - JYSK style -->
