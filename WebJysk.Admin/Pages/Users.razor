@page "/users"
@layout AdminLayout
@inject UserApiService UserApi
@inject IJSRuntime JS

<PageTitle>Users - Jysk Admin</PageTitle>

<AuthRedirect />

<div class="admin-users-page">
    <div class="card border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0">Users</h5>
            <div class="d-flex gap-2">
                <input type="text" class="form-control" style="max-width: 220px;" placeholder="Search by email..." @bind="_filter.Email" />
                <button class="btn btn-primary btn-sm" @onclick="Load">Search</button>
            </div>
        </div>
        <div class="card-body">
            @if (_loading)
            {
                <p class="admin-loading">Loading...</p>
            }
            else
            {
                <div class="table-responsive admin-table-wrap">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Email</th>
                                <th>Full Name</th>
                                <th>Phone</th>
                                <th>Created</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr>
                                    <td class="text-muted">@u.Id</td>
                                    <td class="fw-medium">@u.Email</td>
                                    <td>@u.FullName</td>
                                    <td>@(u.Phone ?? "-")</td>
                                    <td>@u.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u.Id)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (_paged.HasPrevious || _paged.HasNext)
                {
                    <div class="admin-pagination mt-4">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(!_paged.HasPrevious)" @onclick="PrevPage">Previous</button>
                        <span class="text-muted">Page @_paged.Page of @_paged.TotalPages</span>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(!_paged.HasNext)" @onclick="NextPage">Next</button>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<UserModel> _users = [];
    private PagedResult<UserModel> _paged = new();
    private FilterUser _filter = new();
    private PagedQuery _query = new() { Page = 1, PageSize = 15 };
    private bool _loading;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try
        {
            var res = await UserApi.GetAllAsync(_filter, _query);
            if (res != null) { _paged = res; _users = res.Items; }
        }
        finally { _loading = false; }
    }

    private async Task DeleteUser(string id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Delete this user?"))
        {
            await UserApi.DeleteAsync(id);
            await Load();
        }
    }

    private async Task PrevPage() { _query.Page--; await Load(); }
    private async Task NextPage() { _query.Page++; await Load(); }
}
