@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav

<div class="admin-wrapper">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h5>Jysk Admin</h5>
        </div>
        <ul class="sidebar-nav">
            <li>
                <NavLink class="sidebar-link sidebar-link--dashboard" href="/" Match="NavLinkMatch.All">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link sidebar-link--products" href="/products">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></span> Products
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link sidebar-link--categories" href="/categories">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span> Categories
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link" href="/brands">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg></span> Brands
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link sidebar-link--orders" href="/orders">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></span> Orders
                </NavLink>
            </li>
            <li>
                <NavLink class="sidebar-link sidebar-link--users" href="/users">
                    <span class="sidebar-icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span> Users
                </NavLink>
            </li>
        </ul>
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <span class="top-bar-title">JYSK Admin</span>
            <div class="top-bar-actions">
                <a href="http://localhost:5211" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">View Store</a>
                <button type="button" class="btn btn-sm btn-outline-secondary admin-logout-btn" @onclick="Logout">Logout</button>
            </div>
        </header>
        <div class="content-area">
            @Body
        </div>
    </main>
</div>

@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", true);
    }
}
